      border-radius: 0.5rem;
      overflow: hidden;
      border: 1px solid hsl(var(--border));
      background-color: rgba(0, 0, 0, 0.2);
    }
 
    /* Header styling */
    .uploader-notes-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background-color: rgba(255, 153, 0, 0.2);
      border-bottom: 1px solid rgba(255, 153, 0, 0.3);
    }
 
    /* Icon styling */
    .uploader-notes-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 9999px;
      background-color: rgba(255, 153, 0, 0.3);
      flex-shrink: 0;
    }
 
    /* Title styling */
    .uploader-notes-title {
      font-weight: 600;
      font-size: 1rem;
      color: hsl(var(--foreground));
    }
 
    /* Content styling */
    .uploader-notes-content {
      padding: 1rem;
      color: hsl(var(--muted-foreground));
      font-size: 0.9375rem;
      line-height: 1.5;
    }
 
    /* Highlight important text */
    .uploader-notes-highlight {
      color: #ff9900;
      font-weight: 600;
    }
 
    /* List styling inside notes */
    .uploader-notes-list {
      /*margin-top: 0.75rem;*/
      margin-left: 1.25rem;
      list-style-type: disc;
    }
 
    .uploader-notes-list li {
      font-size: medium;
      margin-bottom: 0.5rem;
    }
 
    /* Responsive adjustments */
    @media (max-width: 640px) {
      .uploader-notes {
        margin: 1rem 0;
      }
      
      .uploader-notes-header {
        padding: 0.625rem 0.875rem;
      }
      
      .uploader-notes-icon {
        width: 1.75rem;
        height: 1.75rem;
      }
      
      .uploader-notes-title {
        font-size: 0.9375rem;
      }
      
      .uploader-notes-content {
        padding: 0.875rem;
        font-size: 0.875rem;
      }
    }
 
    /* Collapsible notes functionality */
    .uploader-notes.collapsible .uploader-notes-header {
      cursor: pointer;
      position: relative;
    }
 
    .uploader-notes.collapsible .uploader-notes-toggle {
      margin-left: auto;
      transition: transform 0.2s ease;
    }
 
    .uploader-notes.collapsible[aria-expanded="false"] .uploader-notes-content {
      display: none;
    }
 
    .uploader-notes.collapsible[aria-expanded="false"] .uploader-notes-toggle {
      transform: rotate(180deg);
    }
 
    /* Different note types */
    .uploader-notes.info .uploader-notes-header {
      background-color: rgba(59, 130, 246, 0.2);
