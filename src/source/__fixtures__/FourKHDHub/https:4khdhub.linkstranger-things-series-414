                if (contentFile.classList.contains('hidden')) {
                    header.style.backgroundColor = 'hsl(213deg 69.03% 35.03% / 68%)';
                } else {
                    header.style.backgroundColor = '';
                }

                previousHeader = header;
            });
        });
    }

    // Setup for download headers
    const downloadHeaders = document.querySelectorAll('.download-header');
    setupHeaderClick(
        downloadHeaders,
        header => header.getAttribute('data-file-id').replace('file', ''),
        id => 'content-file' + id
    );

    // Setup for episode headers
    const episodeHeaders = document.querySelectorAll('.episode-header');
    setupHeaderClick(
        episodeHeaders,
        header => header.getAttribute('data-episode-id'),
        id => 'content-' + id
    );
});

