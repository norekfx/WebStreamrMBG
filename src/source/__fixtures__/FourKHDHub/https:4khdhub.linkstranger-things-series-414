    // Function to handle header click logic
    function setupHeaderClick(headers, getId, getContentId) {
        let previousHeader = null;

        headers.forEach(header => {
            header.addEventListener('click', function () {
                const id = getId(header);
                const contentFile = document.getElementById(getContentId(id));

                if (previousHeader && previousHeader !== header) {
                    previousHeader.style.backgroundColor = '';
