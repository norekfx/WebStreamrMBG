<!-- Quality Badges Styles -->
<style>
.quality-badges {
    position: absolute;
    top: 6px;
    right: 6px;
    display: flex;
    flex-direction: row;
    gap: 3px;
    z-index: 10;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: 85%;
}

.quality-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 5px;
    border-radius: 2px;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.3px;
    line-height: 1;
    text-transform: uppercase;
    backdrop-filter: blur(4px);
    transition: all 0.15s ease;
}

/* 4K - Orange/Gold premium */
.badge-4k {
    background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%);
    color: #000;
    border: 1px solid rgba(251, 191, 36, 0.5);
    box-shadow: 0 1px 3px rgba(217, 119, 6, 0.5);
}

/* FHD - Muted dark */
.badge-fhd {
    background: rgba(40, 40, 50, 0.9);
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.12);
}

/* HDR - Red/Orange warm */
.badge-hdr {
    background: linear-gradient(135deg, #b91c1c 0%, #dc2626 100%);
    color: #fff;
    border: 1px solid rgba(220, 38, 38, 0.4);
    box-shadow: 0 1px 3px rgba(185, 28, 28, 0.4);
}

/* DV - Black with white text (Dolby style) */
.badge-dv {
    background: #000;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 2px 4px;
}

/* BD - Blue */
.badge-bd {
    background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%);
    color: #fff;
    border: 1px solid rgba(59, 130, 246, 0.4);
    box-shadow: 0 1px 3px rgba(29, 78, 216, 0.4);
}

/* REMUX - Purple */
.badge-remux {
    background: linear-gradient(135deg, #6b21a8 0%, #9333ea 100%);
    color: #fff;
    border: 1px solid rgba(147, 51, 234, 0.4);
    box-shadow: 0 1px 3px rgba(107, 33, 168, 0.4);
}
/* IMAX - Signature blue with premium feel */
.badge-imax {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    color: #fff;
    border: 1px solid rgba(37, 99, 235, 0.5);
    box-shadow: 0 1px 3px rgba(30, 58, 95, 0.5);
    font-weight: 800;
    letter-spacing: 0.5px;
}

.quality-badge:hover {
    transform: translateY(-1px);
    filter: brightness(1.1);
}
</style>

